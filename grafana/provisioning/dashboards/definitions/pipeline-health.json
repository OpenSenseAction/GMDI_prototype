                    "rawSql": "SELECT\n  time_bucket('1 hour', processed_at) AS time,\n  user_id,\n  COUNT(*) FILTER (WHERE status = 'archived') AS archived\nFROM file_processing_log\nWHERE\n  $__timeFilter(processed_at)\n  AND status = 'archived'\nGROUP BY 1, 2\nORDER BY 1",
                    "format": "time_series",
                    "refId": "A"
                }
            ],
            "title": "Archived files per hour (by user)",
            "type": "timeseries"

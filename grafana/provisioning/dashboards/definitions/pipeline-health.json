                    {
                        "matcher": {
                            "id": "byName",
                            "options": "success_rate_pct"
                        },
                        "properties": [
                            {
                                "id": "custom.displayMode",
                                "value": "gradient-gauge"
                            },
                            {
                                "id": "min",
                                "value": 0
                            },
                            {
                                "id": "max",
                                "value": 100
                            },
                            {
                                "id": "color",
                                "value": {
                                    "mode": "continuous-GrYlRd"
                                }
                            }
                        ]

            },
            "targets": [
                {
                    "datasource": {
                        "type": "grafana-postgresql-datasource",
                        "uid": "${datasource}"
                    },
                    "rawSql": "SELECT\n  user_id,\n  COUNT(*) FILTER (WHERE status = 'archived')    AS archived,\n  COUNT(*) FILTER (WHERE status = 'quarantined') AS quarantined,\n  COUNT(*)                                        AS total,\n  ROUND(\n    100.0 * COUNT(*) FILTER (WHERE status = 'archived') / NULLIF(COUNT(*), 0),\n    1\n  )                                               AS success_rate_pct,\n  COALESCE(SUM(rows_written) FILTER (WHERE status = 'archived'), 0) AS rows_written,\n  MAX(processed_at)                               AS last_activity\nFROM file_processing_log\nWHERE processed_at >= NOW() - INTERVAL '7 days'\nGROUP BY user_id\nORDER BY last_activity DESC",
                    "format": "table",
                    "refId": "A"
                }
            ],
            "title": "Per-user stats (last 7 days)",
            "type": "table"
        },

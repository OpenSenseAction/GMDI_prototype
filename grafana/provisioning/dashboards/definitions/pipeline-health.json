                            {
                                "color": "yellow",
                                "value": 1
                            },
                            {
                                "color": "red",
                                "value": 5
                            }
                        ]
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "quarantined"
                        },
                        "properties": [
                            {
                                "id": "custom.displayMode",
                                "value": "color-background"

# Ignore all files in this directory by default
*

# Except for these files
!.gitignore
!README.md
!generate_ssh_keys.sh

# The actual keys should be generated locally and never committed
# This ensures private keys are never accidentally committed to version control

# Per-user authorized_keys files contain only public keys — safe to track.
!user1/
!user1/authorized_keys
!user2/
!user2/authorized_keys
